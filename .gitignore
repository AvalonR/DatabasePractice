# --- Wails Specific ---
# The actual compiled application (adjust 'db_practice_app' if your binary name is different)
db_practice_app/build/bin/
# Frontend build artifacts
db_practice_app/frontend/dist/
# Wails system-generated bindings (Optional: some keep them, but usually best to let Wails generate them on build)
db_practice_app/frontend/wailsjs/

docs/session_history.md
.opencode
.exe

# --- Frontend / TypeScript ---
# Node dependencies (The biggest source of repo bloat)
db_practice_app/node_modules/
db_practice_app/frontend/node_modules/
# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Build outputs
.parcel-cache
.eslintcache
# Stylelint cache (since you have it installed)
.stylelintcache

# --- OS / IDE Specific ---
# macOS
.DS_Store
# Windows
Thumbs.db
# Neovim/Vim swap files
*.swp
*.swo
# VS Code
.vscode/
# IntelliJ / GoLand
.idea/

